GEMINI_API_KEY=your_api_key_here

# ── Evolution API (WhatsApp automático — Rastreio de Falta) ──────────────────
# URL base da sua instância Evolution API (sem barra no final)
EVOLUTION_API_URL=https://evolution.meuservidor.com.br

# Chave da API (configurada no painel da Evolution API)
EVOLUTION_API_KEY=sua_chave_aqui

# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=farmacia

# Destinos das mensagens — pode ser:
#   • Grupo: JID no formato 120363XXXXXXXXX@g.us
#     (Para obter o JID: Evolution API → GET /group/fetchAllGroups/{instance})
#   • Número individual: formato internacional sem + (ex: 5511999999999)
#   • Múltiplos destinos separados por vírgula
WHATSAPP_TARGETS=120363XXXXXXXXX@g.us
